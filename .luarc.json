{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library",
      "~/.local/share/nvim/site/pack/core/opt" 
    ],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["vim"]
  },
    "diagnostics.disable": [
        "missing-fields"
    ]
}
